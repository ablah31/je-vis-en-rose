# TinaCMS (édition de contenu via /admin)
# En local : `npm run dev:cms` fonctionne sans ces variables.
# En production (Tina Cloud) : créer un projet sur https://app.tina.io
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
TINA_SEARCH_TOKEN=
NEXT_PUBLIC_TINA_BRANCH=main

# Formulaire de contact (Resend) — https://resend.com
# Si absent, le formulaire reste fonctionnel mais l'email n'est pas envoyé (mode démo).
RESEND_API_KEY=
CONTACT_TO_EMAIL=contact@jevisenrose.fr
CONTACT_FROM_EMAIL=onboarding@resend.dev
